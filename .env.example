# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Prisma Accelerate URL (connection pooling) for serverless executions
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=your_accelerate_api_key"
# Direct connection URL to AWS RDS PostgreSQL (used for running migrations)
DIRECT_DATABASE_URL="postgresql://username:password@your-rds-endpoint.amazonaws.com:5432/ushop?schema=public"

# -----------------------------------------------------------------------------
# AUTHENTICATION (Better Auth)
# -----------------------------------------------------------------------------
# Secret token for encryption. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="your_better_auth_secret_here"
# Base URL for the auth system (matches application origin)
BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# AWS SERVICES (S3 Bucket Management)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
AWS_REGION="af-south-1"

# S3 Buckets names
AWS_S3_PRODUCT_IMAGES_BUCKET="ushop-product-images"
AWS_S3_KYC_DOCUMENTS_BUCKET="ushop-kyc-documents"

# -----------------------------------------------------------------------------
# RESEND EMAIL SERVICE
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your_resend_api_key"

# -----------------------------------------------------------------------------
# SENTRY OBSERVABILITY
# -----------------------------------------------------------------------------
# Server-side Sentry DSN
SENTRY_DSN="https://your_sentry_dsn@o000000.ingest.sentry.io/000000"
# Client-side Sentry DSN (must start with NEXT_PUBLIC_ to be exposed to browser)
NEXT_PUBLIC_SENTRY_DSN="https://your_sentry_dsn@o000000.ingest.sentry.io/000000"
# Explicit, justified decision to send/restrict default PII (Personally Identifiable Information) at environment level
SENTRY_SEND_DEFAULT_PII="false"
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII="false"
# Required in CI/CD pipeline to upload sourcemaps
SENTRY_AUTH_TOKEN="your_sentry_auth_token_here"

# -----------------------------------------------------------------------------
# PAYSTACK PAYMENT INTEGRATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_your_paystack_public_key"
PAYSTACK_SECRET_KEY="sk_test_your_paystack_secret_key"
